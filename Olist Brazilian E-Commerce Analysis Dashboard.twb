    <worksheet name='Monthly Orders &amp; Revenue'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Toppan Bunkyu Midashi Gothic' fontsize='12'>Monthly Orders &amp; Revenue</run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Tableau Medium' fontsize='10'>Growth slowed in 2018 after strong 2017 ramp</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#808080' fontname='Anthropic Sans,-apple-system,system-ui,Segoe UI,sans-serif' fontsize='7'>Limited to Aug 2017 – Aug 2018 (13 months). Earlier months are the launch ramp and late 2018 is cut off, so both would skew the trend.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
