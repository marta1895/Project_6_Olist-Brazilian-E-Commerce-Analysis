            </column>
            <column caption='SUM([Pct Of Revenue]/100)' datatype='real' name='[Calculation_5680553668419606]' role='measure' type='quantitative' user:unnamed='Sheet 12'>
              <calculation class='tableau' formula='SUM([pct_of_revenue]/100)' />
            </column>
            <column-instance column='[payment_type]' derivation='None' name='[none:payment_type:nk]' pivot='key' type='nominal' />
            <column caption='Payment Type' datatype='string' name='[payment_type]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;boleto&quot;' value='Boleto' />
                <alias key='&quot;credit_card&quot;' value='Credit card' />
                <alias key='&quot;debit_card&quot;' value='Debit card' />
                <alias key='&quot;voucher&quot;' value='Voucher' />
              </aliases>
            </column>
            <column caption='Pct Of Revenue' datatype='real' default-format='p0.0%' name='[pct_of_revenue]' role='measure' type='quantitative' />
